@using Microsoft.AspNetCore.Http
@using Microsoft.Extensions.Options
@inject ThemeService ThemeService
@inject IOptions<CookieThemeServiceOptions> ThemeCookieOptions

<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <ResourcePreloader />
    <AppRadzenTheme />
    <meta http-equiv="Content-Security-Policy"
               content="base-uri 'self';
               default-src 'self';
               img-src data: https:;
               object-src 'none';
               script-src 'self' 'unsafe-eval' 'wasm-unsafe-eval';
               style-src 'self' 'unsafe-inline';
               upgrade-insecure-requests;">
    <link rel="stylesheet" href="@Assets["app.css"]" />
    <link rel="stylesheet" href="@Assets["blazor-boilerplate.styles.css"]" />
    <ImportMap />
    <link rel="icon" type="image/png" href="favicon.png" />
    <HeadOutlet @rendermode="PageRenderMode" />
</head>

<body>
    <Routes @rendermode="PageRenderMode" />
    <ReconnectModal />
    <script src="@Assets["_framework/blazor.web.js"]"></script>
    <script src="@Assets["_content/Radzen.Blazor/Radzen.Blazor.js"]"></script>
    <script src="@Assets["Components/Account/Shared/PasskeySubmit.razor.js"]" type="module"></script>
</body>

</html>

@code {
    [CascadingParameter]
    private HttpContext HttpContext { get; set; } = default!;

    protected override void OnInitialized()
    {
        if (HttpContext is null)
        {
            return;
        }

        var theme = HttpContext.Request.Cookies[blazor_boilerplate.Shared.ServiceCollectionExtensions.ThemeCookieName];
        if (!string.IsNullOrWhiteSpace(theme))
        {
            ThemeService.SetTheme(theme, false);
            return;
        }

        HttpContext.Response.Cookies.Append(
            blazor_boilerplate.Shared.ServiceCollectionExtensions.ThemeCookieName,
            blazor_boilerplate.Shared.ServiceCollectionExtensions.DefaultTheme,
            new CookieOptions
            {
                Secure = ThemeCookieOptions.Value.IsSecure,
                Expires = DateTimeOffset.Now.Add(ThemeCookieOptions.Value.Duration)
            });
    }

    private IComponentRenderMode? PageRenderMode =>
        HttpContext.AcceptsInteractiveRouting() ? InteractiveAuto : null;
}
