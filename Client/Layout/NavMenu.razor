@implements IDisposable

@inject NavigationManager NavigationManager

<RadzenStack Gap="0" class="app-navigation">
    <NavLink class="app-brand" href="" Match="NavLinkMatch.All">blazor-boilerplate</NavLink>

    <nav class="app-nav-list">
        <NavLink class="app-nav-link" href="" Match="NavLinkMatch.All">
            <RadzenIcon Icon="home" /> Home
        </NavLink>

        <NavLink class="app-nav-link" href="counter">
            <RadzenIcon Icon="add_box" /> Counter
        </NavLink>

        <NavLink class="app-nav-link" href="weather">
            <RadzenIcon Icon="table_chart" /> Weather
        </NavLink>

        <NavLink class="app-nav-link" href="auth">
            <RadzenIcon Icon="lock" /> Auth Required
        </NavLink>

        <AuthorizeView>
            <Authorized>
                <NavLink class="app-nav-link" href="Account/Manage">
                    <RadzenIcon Icon="account_circle" /> @context.User.Identity?.Name
                </NavLink>
                <form action="Account/Logout" method="post">
                    <AntiforgeryToken />
                    <input type="hidden" name="ReturnUrl" value="@currentUrl" />
                    <button type="submit" class="app-nav-link app-nav-button">
                        <RadzenIcon Icon="logout" /> Logout
                    </button>
                </form>
            </Authorized>
            <NotAuthorized>
                <NavLink class="app-nav-link" href="Account/Register">
                    <RadzenIcon Icon="person_add" /> Register
                </NavLink>
                <NavLink class="app-nav-link" href="Account/Login">
                    <RadzenIcon Icon="login" /> Login
                </NavLink>
            </NotAuthorized>
        </AuthorizeView>
    </nav>
</RadzenStack>

@code {
    private string? currentUrl;

    protected override void OnInitialized()
    {
        currentUrl = NavigationManager.ToBaseRelativePath(NavigationManager.Uri);
        NavigationManager.LocationChanged += OnLocationChanged;
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        currentUrl = NavigationManager.ToBaseRelativePath(e.Location);
        StateHasChanged();
    }

    public void Dispose()
    {
        NavigationManager.LocationChanged -= OnLocationChanged;
    }
}

